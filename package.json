{
  "name": "my-app",
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev",
    "build": "npm run build:client && vite build",
    "build:client": "vite build --mode dev --outDir public/",
    "preview": "npm run build && wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "hono": "^4.12.5",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.10.0",
    "@hono/vite-dev-server": "^0.25.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "vite": "^7.3.1",
    "wrangler": "^4.71.0"
  }
}
